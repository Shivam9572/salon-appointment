# ============================================
#   .gitignore — Node.js + Next.js (TypeScript)
#   Covers: backend/, frontend/, salon-user-frontend/
# ============================================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ----- Environment Variables (NEVER upload these) -----
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ----- Next.js Build Output -----
.next/
out/
build/
dist/

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Runtime / OS -----
.DS_Store
Thumbs.db
*.pem

# ----- Testing -----
coverage/
.nyc_output/

# ----- Cache -----
.npm
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
*.tsbuildinfo

# ----- Editor / IDE -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Prisma -----
prisma/migrations/**/migration_lock.toml

# ----- Docker (local only) -----
docker-compose.override.yml

# ----- Uploads / Media (user generated) -----
uploads/
public/uploads/

# ----- Misc -----
*.orig
*.bak
.vercel